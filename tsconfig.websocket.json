{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "./build-rpc"
  },
  "include": ["websocket.ts"],
  "exclude": ["node_modules", "dist", "resources", "src"]
}

