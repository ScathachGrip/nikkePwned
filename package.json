{
  "name": "nikkepwned",
  "description": "Password Manager for NIKKE",
  "funding": "https://github.com/sponsors/sinkaroid",
  "version": "3.0.1-indev",
  "scripts": {
    "clean": "rimraf --glob \"dist\" \"build\" \"out\" \"release\" \"*.exe\" \"*.zip\"",
    "prebuild": "ts-node src/frontend.ts",
    "build": "npm run clean && tsc",
    "start": "neu run",
    "start:dev": "tsc && npm run start",
    "update": "neu update",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:rpc": "rimraf discord-rpc.exe && pkg discord-rpc.cjs --targets node18-win-x64 --output discord-rpc.exe",
    "prettierrc": "prettier --write \"**/*.ts\"",
    "linter": "npm run prettierrc && npm run lint:fix",
    "release": "npm run clean && npm run build && npm run build:rpc && node -e \"const fs=require('fs');fs.mkdirSync('dist/nikkepwned',{recursive:true});fs.copyFileSync('discord-rpc.exe','dist/nikkepwned/discord-rpc.exe');\" && neu build --release",
    "build:fresh": "npm run clean && npm run update && npm run build && npm run release && npm run build:rpc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ScathachGrip/nikkePwned.git"
  },
  "author": "sinkaroid",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ScathachGrip/nikkePwned/issues"
  },
  "homepage": "https://github.com/ScathachGrip/nikkePwned",
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/discord-rpc": "^4.0.8",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "neutralinojs-types": "^2.0.0",
    "pkg": "^5.8.1",
    "prettier": "^3.5.2",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8.24.1"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  }
}